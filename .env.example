DOC2RAG_LLM_PROVIDER=openai
DOC2RAG_OPENAI_API_KEY=
DOC2RAG_OPENAI_MODEL=gpt-4o
DOC2RAG_GEMINI_API_KEY=
DOC2RAG_GEMINI_MODEL=gemini-1.5-pro

DOC2RAG_GCP_PROJECT_ID=
DOC2RAG_GCP_LOCATION=us
DOC2RAG_DOCAI_PROCESSOR_ID=

# Separate from the DOC2RAG_-prefixed settings above: this is the standard
# GCP client-library env var pointing at a service-account JSON key, picked
# up automatically by google-cloud-documentai. Not read via Settings.
GOOGLE_APPLICATION_CREDENTIALS=
