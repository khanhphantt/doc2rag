DOC2RAG_LLM_PROVIDER=openai
DOC2RAG_OPENAI_API_KEY=
DOC2RAG_OPENAI_MODEL=gpt-4o
DOC2RAG_GEMINI_API_KEY=
DOC2RAG_GEMINI_MODEL=gemini-1.5-pro

DOC2RAG_OCR_LANG=japan
DOC2RAG_OCR_CONFIDENCE_THRESHOLD=0.80

DOC2RAG_MONGO_URI=mongodb://localhost:27017
DOC2RAG_MONGO_DB=doc2rag
DOC2RAG_MONGO_CHUNKS_COLLECTION=checkup_chunks

DOC2RAG_EMBEDDING_MODEL=text-embedding-3-small
DOC2RAG_EMBEDDING_DIM=1536

DOC2RAG_PDF_RENDER_DPI=300
